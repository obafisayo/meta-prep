# Postgres (Vercel Postgres / Neon integration sets this automatically in production)
DATABASE_URL=

# Resend — https://resend.com/api-keys
RESEND_API_KEY=
# Verified sender, or leave unset to use Resend's shared test domain
RESEND_FROM="Meta PE Prep <onboarding@resend.dev>"
# Where the daily digest email goes
DIGEST_EMAIL_TO=abimbolaobafisayo@gmail.com

# Web Push VAPID keys — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:abimbolaobafisayo@gmail.com

# Public URL of the deployed app (used in email/push links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Shared secret Vercel Cron sends as a Bearer token; set the same value in
# Vercel project settings so /api/cron/daily rejects unauthenticated calls
CRON_SECRET=

# Anthropic API key (platform.claude.com) — powers the Study Command Centre's
# quizzes, mock interviews, and tutor sessions via /api/claude. Server-side
# only; never exposed to the browser.
ANTHROPIC_API_KEY=
